{
	"name": "@ckohen/savona",
	"version": "0.1.4",
	"description": "Library for talking to PXW-Z190V cameras",
	"type": "module",
	"scripts": {
		"clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
		"prepack": "yarn build",
		"prepublishOnly": "yarn lint",
		"lint": "eslint src --ext ts && tsc --noEmit",
		"lint:fix": "eslint src --ext ts --fix",
		"format": "prettier --write . && eslint src --ext ts --fix",
		"format:fix": "prettier --write .",
		"build": "yarn clean && tsc",
		"test": "yarn build && node --test test/*.test.mjs"
	},
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		}
	},
	"engines": {
		"node": ">=22"
	},
	"publishConfig": {
		"access": "public"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/ckohen/savona.git"
	},
	"author": "",
	"license": "ISC",
	"bugs": {
		"url": "https://github.com/ckohen/savona/issues"
	},
	"homepage": "https://github.com/ckohen/savona#readme",
	"dependencies": {
		"@msgpack/msgpack": "^3.1.3",
		"@vladfrangu/async_event_emitter": "^2.4.7",
		"digest-fetch": "^3.1.1",
		"ws": "^8.21.0",
		"xml2js": "^0.6.2"
	},
	"devDependencies": {
		"@eslint/compat": "^2.1.0",
		"@types/node": "^24.13.3",
		"@types/websocket": "^1.0.10",
		"@types/ws": "^8.18.1",
		"@types/xml2js": "^0.4.14",
		"eslint": "^10.7.0",
		"eslint-config-neon": "^0.5.4",
		"eslint-formatter-pretty": "^7.1.0",
		"lodash.merge": "^4.6.2",
		"prettier": "^3.9.5",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.63.0"
	},
	"packageManager": "yarn@4.17.0"
}
